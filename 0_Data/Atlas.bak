table.sort(WoWTools_Atlas.atlas)

--[[function WoWTools_Atlas:Menu(root, GetValue, SetValue)
    for index, name in pairs(self.atlas) do
        local isAtlas, textureID, icon= WoWTools_TextureMixin:IsAtlas(name, 32)
        if isAtlas then
            local sub= root:CreateCheckbox(
                icon,
            function(data)
                GetValue(data.name, data)
            end, function(data)
                SetValue(data.name, data)
            end, {name=name, icon=icon, textureID=textureID, rightText= DISABLED_FONT_COLOR:WrapTextInColorCode(index)})
            WoWTools_MenuMixin:SetRightText(sub)
        elseif WoWTools_DataMixin.Player.husandro then
            print('没发现 WoWTools_Atlas', name)
        end
    end
end]]

--if _G['TAV_CoreFrame'] then--查找，图标，按钮， Texture Atlas Viewer， 插件
function WoWTools_Atlas:CreateButton(frame, GetValue, SetValue, tab)
    tab= tab or {}

    local tav= CreateFrame('DropdownButton', tab.name or nil, frame, 'WoWToolsMenu3Template')-- WoWTools_ButtonMixin:Cbtn(Frame, {size=22, atlas='communities-icon-searchmagnifyingglass'})
    tav:SetNormalAtlas("communities-icon-searchmagnifyingglass")

    if tab.SetPoint then
        tab.SetPoint(tav)
    end

    if _G['TAV_CoreFrame'] then
        tav.tooltip= WoWTools_DataMixin.Icon.right..'Texture Atlas Viewer'
        tav.owner= tab.owner
        tav:SetScript('OnMouseDown', function(btn, d)
            if d=='RightButton' then
                local f= _G['TAV_CoreFrame']
                f:SetShown(not frame:IsShown())
                if f:IsShown() and frame.LeftInset and frame.LeftInset.SearchBox and frame.LeftInset.SearchBox:GetText()=='' then
                    f.LeftInset.SearchBox:SetText('objec')
                end
                btn:CloseMenu()
            end
        end)
    end

    tav:SetupMenu(function(btn, root)
        if not btn:IsMouseOver() then
            return
        end
        for index, name in pairs(self.atlas) do
            local isAtlas, textureID, icon= WoWTools_TextureMixin:IsAtlas(name, 42)
            if isAtlas then
                local sub= root:CreateCheckbox(
                    icon,
                function(data)
                    GetValue(data.name, data)
                end, function(data)
                    SetValue(data.name, data)
                end, {name=name, icon=icon, textureID=textureID, rightText= DISABLED_FONT_COLOR:WrapTextInColorCode(index)})
                sub:AddInitializer(function(b)
                    return 120, 46
                end)
                WoWTools_MenuMixin:SetRightText(sub)
                sub:SetTooltip(function(tooltip, desc)
                    tooltip:AddLine(desc.data.name)
                end)

            elseif WoWTools_DataMixin.Player.husandro then
                print('没发现 WoWTools_Atlas', name)
            end
        end
        WoWTools_MenuMixin:SetScrollMode(root)
    end)

    return tav
end

    --[[WoWTools_Atlas:CreateButton(Frame, function(name)
        return string.lower(Frame.iconEdit:GetText())==string.lower(name)
    end, function(name)
        Frame.iconEdit:SetText(name)
    end, {
        SetPoint=function(btn)
            btn:SetPoint('LEFT', Frame.iconEdit.iconButton, 'RIGHT')
        end,
        owner= 'ANCHOR_RIGHT'
    })]]